# Leave empty for local development; Vite proxies /api to the backend.
VITE_API_BASE_URL=
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Vercel Cron authorization secret. Configure this in Vercel, never in Vite.
CRON_SECRET=generate-a-long-random-secret
