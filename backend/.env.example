PORT=5000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Public verification base URL (IMPORTANT: set this to your final Vercel domain before generating production QR codes)
PUBLIC_VERIFICATION_BASE_URL=https://tg-verification-xi.vercel.app

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Secret for admin sessions (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=24h
